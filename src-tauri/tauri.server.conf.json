{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Metalu Server",
  "version": "0.1.0",
  "identifier": "cl.metalu.server",
  "build": {
    "frontendDist": "http://localhost:3000",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Metalu Server",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../.next/standalone/**"]
  }
}
