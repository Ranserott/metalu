{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Metalu Server",
  "version": "0.1.0",
  "identifier": "cl.metalu.server",
  "build": {
    "frontendDist": "../out",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Metalu Server",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
