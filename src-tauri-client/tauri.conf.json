{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Metalu Cliente",
  "version": "0.2.0",
  "identifier": "cl.metalu.client",
  "build": {
    "frontendDist": null,
    "devUrl": null,
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Metalu Cliente",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "category": "Business",
    "shortDescription": "Metalu Cliente LAN",
    "longDescription": "Cliente LAN para MetalFlow ERP. Conecta al servidor Metalu via UDP discovery."
  }
}
